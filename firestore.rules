rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 文字雲：任何人可讀寫
    match /wordcloud_words/{document} {
      allow read, write: if true;
    }

    // 訪客預約
    //  create: 匿名只能建立 pending；登入使用者（員工邀約）可直接建 approved
    //  read:   任何人可讀（訪客憑 token 查自己、保衛室列出今日清單）
    //  update: 僅登入使用者可更新（核可、報到、退件）
    //  delete: 僅登入使用者可刪除（admin-data 清除舊資料工具用）
    match /visitors/{visitorId} {
      allow create: if request.resource.data.qrToken is string
                    && request.resource.data.name is string
                    && request.resource.data.hostName is string
                    && (
                      request.resource.data.status == 'pending'
                      || request.auth != null
                    );
      allow read: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // VIP 名冊：僅登入使用者可讀寫
    match /vips/{vipId} {
      allow read, write: if request.auth != null;
    }

    // 員工檔案：登入者可讀，本人可寫
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 其他集合預設禁止
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
